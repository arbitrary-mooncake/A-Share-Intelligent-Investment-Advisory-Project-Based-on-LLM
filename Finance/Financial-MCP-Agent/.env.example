# ============================================================
# 股票投资顾问 Agent — 环境变量配置
# ============================================================
# 四模型架构（按任务特性分配最优模型）：
#
#   Model 1 (MiMo-V2.5-Pro):  报告撰写 + 中/长线打分（中文金融最强 85.6%）
#   Model 2 (Qwen3.6-Flash):  快速查询 + 快筛股票池（速度优先，不动）
#   Model 3 (Qwen3.6-Plus):   技术分析 + 新闻分析 + 短线打分（性价比之选）
#   Model 4 (Kimi K2.6):      基本面分析 + 估值分析（Agent/数学最强）
# ============================================================

# ──────────────────────────────────────────────
# Model 1: MiMo-V2.5-Pro（小米API）
# 用途: summary_agent / medium_term_scorer / long_term_scorer
# ──────────────────────────────────────────────
OPENAI_COMPATIBLE_API_KEY=your_mimo_api_key_here
OPENAI_COMPATIBLE_BASE_URL=https://api.xiaomimimo.com/v1
OPENAI_COMPATIBLE_MODEL=mimo-v2.5-pro

# ──────────────────────────────────────────────
# Model 2: Qwen3.6-Flash（阿里百炼API）
# 用途: 快速查询 + 快筛股票池全链路（不动）
# ──────────────────────────────────────────────
OPENAI_COMPATIBLE_API_KEY_2=your_qwen_api_key_here
OPENAI_COMPATIBLE_BASE_URL_2=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_COMPATIBLE_MODEL_2=qwen3.6-flash

# ──────────────────────────────────────────────
# Model 3: Qwen3.6-Plus（阿里百炼API）
# 用途: technical_agent / news_agent / short_term_scorer
# ──────────────────────────────────────────────
OPENAI_COMPATIBLE_API_KEY_3=your_qwen_api_key_here
OPENAI_COMPATIBLE_BASE_URL_3=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_COMPATIBLE_MODEL_3=qwen3.6-plus

# ──────────────────────────────────────────────
# Model 4: Kimi K2.6（月之暗面API）
# 用途: fundamental_agent / value_agent
# ──────────────────────────────────────────────
OPENAI_COMPATIBLE_API_KEY_4=your_kimi_api_key_here
OPENAI_COMPATIBLE_BASE_URL_4=https://api.moonshot.cn/v1
OPENAI_COMPATIBLE_MODEL_4=kimi-k2.6

# ──────────────────────────────────────────────
# Model 5: MiMo-V2.5（小米API）
# 用途: 智能问答主模型（qa_engine）
# ──────────────────────────────────────────────
OPENAI_COMPATIBLE_API_KEY_5=your_mimo_api_key_here
OPENAI_COMPATIBLE_BASE_URL_5=https://api.xiaomimimo.com/v1
OPENAI_COMPATIBLE_MODEL_5=mimo-v2.5

# ──────────────────────────────────────────────
# LLM 模式设置
# ──────────────────────────────────────────────
USE_LOCAL_MODEL=api

# ============================================================
# 各模块模型分配（由 src/utils/model_config.py 集中管理）：
#
#   summary_agent        → Model 1 (MiMo-V2.5-Pro) | thinking enabled  | 32K, timeout 720s
#   medium_term_scorer   → Model 1 (MiMo-V2.5-Pro) | thinking enabled  | 16K, timeout 360s
#   long_term_scorer     → Model 1 (MiMo-V2.5-Pro) | thinking enabled  | 16K, timeout 360s
#   fundamental_agent    → Model 4 (Kimi K2.6)     | thinking disabled |  8K, timeout 360s
#   value_agent          → Model 4 (Kimi K2.6)     | thinking disabled |  8K, timeout 360s
#   technical_agent      → Model 3 (Qwen3.6-Plus)  | thinking disabled |  8K, timeout 360s
#   news_agent           → Model 3 (Qwen3.6-Plus)  | thinking disabled | 32K, timeout 360s
#   short_term_scorer    → Model 3 (Qwen3.6-Plus)  | thinking enabled  | 16K, timeout 360s
#
#   快筛股票池全链路       → Model 2 (Qwen3.6-Flash) | 由 scoring_engine 覆盖
#   快速查询              → Model 2 (Qwen3.6-Flash) | 由 api/app.py 直接指定
#
#   分配逻辑：
#   - 金融判断用 MiMo（中文金融 ReLE 85.6%）
#   - 工具编排用 Kimi（SWE-Bench Pro #1, GPQA 90.5%）
#   - 够用就省用 Qwen（¥2/M 输入, 中文幻觉最低 96.9%）
# ============================================================
