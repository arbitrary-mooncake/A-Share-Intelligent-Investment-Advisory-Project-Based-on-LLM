# Environment variables (API keys, secrets)
.env
.env.*
!.env.example

# Python virtual environment
venv/
.venv/

# Python bytecode cache
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store

# IDE
.vscode/
.idea/

# Logs (含运行时生成的 execution_info / agent_execution 等 JSON)
*.log
logs/

# Git worktrees
.worktrees/

# Build artifacts
*.egg-info/
dist/
build/

# ─── 运行时数据 / 缓存 / 报告 ─────────────────────────────
