# ============================================================
# A股智能投顾Agent助手 — 环境变量配置
# ============================================================
#
# 双版本架构：
#   lite = 精简版（DeepSeek 单一 API + 免费 Tushare + AKShare）
#   full = 完整版（6 模型 + Tushare 5000 积分）
#
# 首次运行可通过导览页面自动配置，也可手动编辑此文件。
# ============================================================

# ─── 模式选择 ─────────────────────────────────────────────
# lite = 精简版（推荐新手试用）
# full = 完整版（需要完整的 API Key 配置）
APP_MODE=full

# ═══════════════════════════════════════════════════════════
# 精简版配置（APP_MODE=lite 时使用）
# ═══════════════════════════════════════════════════════════

# DeepSeek API（精简版唯一需要的 LLM Key）
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_PRO=deepseek-v4-pro
DEEPSEEK_MODEL_FLASH=deepseek-v4-flash

# ═══════════════════════════════════════════════════════════
# 完整版配置（APP_MODE=full 时使用）
# ═══════════════════════════════════════════════════════════
# 六模型架构（按任务特性分配最优模型）：
#
#   Model 1 (MiMo-V2.5-Pro):   报告撰写 / 中长线打分 / 基本面 / 估值 / 质量风险
#   Model 2 (Qwen3.6-Flash):   快速查询 / 快筛股票池
#   Model 3 (Qwen3.7-Plus):    技术分析 / 新闻 / 短线打分 / 事件 / 资金流 / 基金子代理
#   Model 4 (保留位):           已迁移到 M1，保留位避免破坏配置读取
#   Model 5 (DeepSeek V4 Flash):智能问答主模型 / 评测系统 agent 分析
#   Model 6 (DeepSeek V4 Pro): 评测系统运筹调度 / LLM 自由投资线

# ─── Model 1: MiMo-V2.5-Pro（小米 API）─────────────────────
OPENAI_COMPATIBLE_API_KEY=your_mimo_api_key_here
OPENAI_COMPATIBLE_BASE_URL=https://api.xiaomimimo.com/v1
OPENAI_COMPATIBLE_MODEL=mimo-v2.5-pro

# ─── Model 2: Qwen3.6-Flash（阿里百炼 API）────────────────
OPENAI_COMPATIBLE_API_KEY_2=your_qwen_api_key_here
OPENAI_COMPATIBLE_BASE_URL_2=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_COMPATIBLE_MODEL_2=qwen3.6-flash

# ─── Model 3: Qwen3.7-Plus（阿里百炼 API）─────────────────
OPENAI_COMPATIBLE_API_KEY_3=your_qwen_api_key_here
OPENAI_COMPATIBLE_BASE_URL_3=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_COMPATIBLE_MODEL_3=qwen3.7-plus

# ─── Model 4: 保留位（已迁移到 M1）─────────────────────────
OPENAI_COMPATIBLE_API_KEY_4=
OPENAI_COMPATIBLE_BASE_URL_4=
OPENAI_COMPATIBLE_MODEL_4=

# ─── Model 5: DeepSeek V4 Flash（DeepSeek API）────────────
OPENAI_COMPATIBLE_API_KEY_5=your_deepseek_api_key_here
OPENAI_COMPATIBLE_BASE_URL_5=https://api.deepseek.com/v1
OPENAI_COMPATIBLE_MODEL_5=deepseek-v4-flash

# ─── Model 6: DeepSeek V4 Pro（DeepSeek API）──────────────
OPENAI_COMPATIBLE_API_KEY_6=your_deepseek_api_key_here
OPENAI_COMPATIBLE_BASE_URL_6=https://api.deepseek.com/v1
OPENAI_COMPATIBLE_MODEL_6=deepseek-v4-pro

# ─── LLM 模式设置 ─────────────────────────────────────────
# api = 使用 OpenAI 兼容 API（默认）
USE_LOCAL_MODEL=api

# ─── Tushare API（A 股金融数据）────────────────────────────
# 申请地址: https://tushare.pro/register
# 精简版：120 积分（免费注册即可）
# 完整版：5000+ 积分（付费会员）
# 用于: MCP tushare_mcp_server / tushare_client.py / 批量打分 / 评测系统
TUSHARE_TOKEN=your_tushare_token_here
TUSHARE_URL=https://api.tushare.pro
