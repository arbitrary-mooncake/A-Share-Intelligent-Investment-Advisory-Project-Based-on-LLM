data/
reports/
stock_pool.json
fund_pool.json
*.cache

# ─── 运行时状态目录 ───────────────────────────────────────
.run/
.pytest_cache/
.ipynb_checkpoints/

# ─── Streamlit 本地密钥 ───────────────────────────────────
.streamlit/secrets.toml

# ─── Claude Code / Superpowers 本地状态 ───────────────────
.claude/
.superpowers/

