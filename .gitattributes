# Normalize line endings — force LF for all text files
# This ensures consistent line endings across Windows/Linux/WSL/Mac
* text=auto eol=lf

# Explicit LF for source code
*.py     text eol=lf
*.sh     text eol=lf
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.toml   text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.csv    text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.ts     text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
*.env    text eol=lf
*.sql    text eol=lf
Dockerfile   text eol=lf
Makefile     text eol=lf
.gitignore   text eol=lf

# Windows-only scripts keep CRLF
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# Binary files — never normalize
*.pdf    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.bmp    binary
*.db     binary
*.sqlite binary
*.sqlite3 binary
*.pkl    binary
*.parquet binary
*.xlsx   binary
*.xls    binary
*.zip    binary
*.gz     binary
*.tar    binary
*.7z     binary
*.exe    binary
*.dll    binary
*.so     binary
*.dylib  binary
